// Prisma schema — ACCELERATE Tanzania Seed Registry
// T-1 scaffold: datasource + generator only.
// T-2: Actor / Crop / CropsOnActors models + ConsentStatus enum (design.md §5).

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; "rhel-openssl-3.0.x" for the nodejs20.x Lambda
  // runtime (Amazon Linux 2023 / OpenSSL 3) so the deployed function ships the
  // matching query engine binary (infra/aws-deployment T-3, design.md §4/§9).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ConsentStatus {
  GRANTED
  DENIED
  UNKNOWN
}

model Actor {
  id               String          @id @default(cuid())
  traderId         String          @unique
  traderName       String
  region           String
  district         String?
  traderType       String
  sex              String?
  position         String?
  marketLocation   String?
  capacityTons     Decimal?        @db.Decimal(10, 2)
  technicalSupport String?         @db.Text
  phone            String? // PII
  email            String? // PII
  gpsLatitude      Decimal?        @db.Decimal(10, 7)
  gpsLongitude     Decimal?        @db.Decimal(10, 7)
  gpsAltitude      Decimal?        @db.Decimal(10, 2)
  gpsAccuracy      Decimal?        @db.Decimal(10, 2)
  consentStatus    ConsentStatus   @default(UNKNOWN)
  crops            CropsOnActors[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([region])
  @@index([traderType])
  @@index([consentStatus])
  @@index([traderName])
}

model Crop {
  id     String          @id @default(cuid())
  name   String          @unique // "sorghum" | "common_bean" | "groundnut"
  actors CropsOnActors[]
}

model CropsOnActors {
  actor   Actor  @relation(fields: [actorId], references: [id], onDelete: Cascade)
  actorId String
  crop    Crop   @relation(fields: [cropId], references: [id], onDelete: Cascade)
  cropId  String

  @@id([actorId, cropId])
}

enum ActorAuditAction {
  CREATE
  UPDATE
  DELETE
  BULK_CONSENT
  BULK_DELETE
  IMPORT
}

model ActorAuditLog {
  id           String           @id @default(cuid())
  // Plain string — deliberately NO relation/FK so rows survive actor deletion.
  actorId      String
  // Identity snapshot so history stays meaningful after deletion.
  traderId     String
  traderName   String
  action       ActorAuditAction
  actingSub    String
  actingEmail  String?
  changes      Json
  acknowledged Boolean?
  createdAt    DateTime         @default(now())

  @@index([actorId, createdAt])
}
